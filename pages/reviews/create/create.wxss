/* ========== 写评价 — 页面样式 ========== */
.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.order-ref {
  padding: 24rpx;
  font-size: 26rpx;
  color: #999999;
}

.rating-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.rating-label {
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
  margin-bottom: 16rpx;
  text-align: center;
}

.rating-stars {
  display: flex;
  justify-content: center;
  gap: 24rpx;
}

.star {
  font-size: 56rpx;
  color: #E5E7EB;
  transition: transform 0.15s;
}
.star.on {
  color: #F59E0B;
}
.star:active {
  transform: scale(1.2);
}

.rating-hint {
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.content-card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}

.content-card .form-label {
  margin-bottom: 16rpx;
}

.content-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 16rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.8;
  color: #1A1A1A;
}
.content-textarea:focus {
  border-color: #F97316;
  background: #FFFFFF;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.submit-area {
  padding: 0 24rpx 24rpx;
  padding-bottom: calc(24rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
.submit-area .save-btn {
  width: 100%;
}
