<!-- 我的（TabBar 页面） -->
<view class="mine-page">
  <view class="user-card card">
    <view class="avatar {{profileAccent}}">👤</view>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="role-badge">{{roleBadge}}</view>
      <view class="role">{{roleText}}</view>
      <view class="role-desc">{{roleDesc}}</view>
    </view>
  </view>

  <view class="upgrade-banner" wx:if="{{userInfo.role === 'OWNER'}}" bindtap="goTo" data-path="/pages/feeder/apply/apply">
    <view class="upgrade-kicker">身份升级</view>
    <view class="upgrade-title">申请成为喂养员</view>
    <view class="upgrade-desc">提交实名和服务资料，通过审核后即可进入接单模式。</view>
  </view>

  <view class="menu-group" wx:for="{{menuGroups}}" wx:key="id">
    <view class="group-title">{{item.title}}</view>
    <view class="menu-list">
      <view class="menu-item" wx:for="{{item.items}}" wx:key="id" bindtap="onMenuTap" data-path="{{item.path}}" data-action="{{item.action}}">
        <text>{{item.text}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <button class="btn btn-default logout-btn" bindtap="doLogout">退出登录</button>
</view>
