.user-card { display: flex; align-items: center; padding: 40rpx 30rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; font-size: 50rpx; margin-right: 24rpx; }
.nickname { font-size: 34rpx; font-weight: 600; margin-bottom: 6rpx; }
.role { font-size: 26rpx; color: #6b7280; }

.menu-list { margin-top: 20rpx; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 28rpx 30rpx; background: #fff; font-size: 30rpx; border-bottom: 1px solid #f3f4f6; }
.arrow { color: #d1d5db; font-size: 36rpx; }
