/* ========== 订单列表 ========== */
.orders-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}

.page-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 25rpx;
  line-height: 1.6;
  color: #666666;
}

.tabs {
  display: flex;
  margin-bottom: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999999;
  position: relative;
}
.tab.active {
  color: #F97316;
  font-weight: 500;
}
.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: #F97316;
  border-radius: 2rpx;
}

.order-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.oc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.oc-no {
  font-size: 24rpx;
  color: #999999;
}

.oc-info {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.8;
}
.oc-info text {
  display: block;
}

.oc-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
  flex-wrap: wrap;
}
.oc-actions button {
  margin: 0;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
}
