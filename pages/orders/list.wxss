.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.orders-owner {
  background: linear-gradient(180deg, #fff8ef 0%, #f7f8fb 100%);
}

.orders-feeder {
  background: linear-gradient(180deg, #eef7ff 0%, #f4f7fb 100%);
}

.orders-admin {
  background: linear-gradient(180deg, #eff1f5 0%, #f8fafc 100%);
}

.header-card {
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.header-owner {
  background: linear-gradient(135deg, #fff3e2 0%, #ffe1bf 100%);
}

.header-feeder {
  background: linear-gradient(135deg, #e0f2fe 0%, #c7e7ff 100%);
}

.header-admin {
  background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.65);
  color: #475569;
  font-size: 22rpx;
  font-weight: 600;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 25rpx;
  line-height: 1.6;
  color: #475569;
}

.tabs {
  display: flex;
  margin-bottom: 20rpx;
  background: rgba(255,255,255,0.92);
  border-radius: 18rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.04);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #6b7280;
}

.tab.active {
  color: #2563eb;
  font-weight: 700;
  border-bottom: 4rpx solid #2563eb;
  background: rgba(255,255,255,0.7);
}

.order-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  border-radius: 20rpx;
  background: rgba(255,255,255,0.94);
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.05);
}

.oc-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.oc-no {
  font-size: 24rpx;
  color: #94a3b8;
}

.oc-info {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.8;
}

.oc-info text {
  display: block;
}

.oc-actions {
  margin-top: 16rpx;
  text-align: right;
}

.btn-sm {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  border: 1px solid #d1d5db;
  background: #fff;
}

.btn-sm.danger {
  color: #ef4444;
  border-color: #fca5a5;
}

.btn-sm.primary {
  color: #2563eb;
  border-color: #93c5fd;
}

.empty {
  text-align: center;
  padding: 80rpx 24rpx;
  color: #94a3b8;
  font-size: 26rpx;
}
