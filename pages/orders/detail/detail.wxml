<!-- 订单详情 -->
<view class="detail-page">
  <view class="header-card {{headerCardClass}}">
    <view class="role-badge">{{roleBadgeText}}</view>
    <view class="page-title">{{pageTitle}}</view>
  </view>

  <view class="status-banner status-banner-{{statusLower}}">
    {{statusMap[order.status]}} — {{statusDescMap[order.status]}}
  </view>

  <view class="card detail-card">
    <view class="detail-row">
      <text class="dl">订单编号</text>
      <text class="dv">{{order.orderNo}}</text>
    </view>
    <view class="detail-row">
      <text class="dl">宠物</text>
      <text class="dv">{{order.petName || '--'}}</text>
    </view>
    <view class="detail-row">
      <text class="dl">服务日期</text>
      <text class="dv">{{order.serviceDate}}</text>
    </view>
    <view class="detail-row">
      <text class="dl">时段</text>
      <text class="dv">{{periodMap[order.servicePeriod]}}</text>
    </view>
    <view class="detail-row">
      <text class="dl">地址</text>
      <text class="dv">{{order.address}}</text>
    </view>
    <view class="detail-row">
      <text class="dl">金额</text>
      <text class="dv price" wx:if="{{order.price}}">¥{{order.price}}</text>
      <text class="dv" wx:else>待喂养员报价</text>
    </view>
    <view class="detail-row" wx:if="{{order.notes}}">
      <text class="dl">备注</text>
      <text class="dv">{{order.notes}}</text>
    </view>
  </view>

  <view class="actions" wx:if="{{canAccept}}">
    <button class="btn btn-primary" bindtap="doAccept">接单</button>
  </view>
  <view class="actions" wx:if="{{canQuote}}">
    <button class="btn btn-primary" bindtap="doQuote">填报价</button>
  </view>
  <view class="actions" wx:if="{{canConfirm}}">
    <button class="btn btn-primary" bindtap="doConfirm">同意报价</button>
  </view>
  <view class="actions" wx:if="{{canReject}}">
    <button class="btn btn-outline" bindtap="doReject">拒绝报价</button>
  </view>
  <view class="actions" wx:if="{{canStart}}">
    <button class="btn btn-primary" bindtap="doStart">开始服务</button>
  </view>
  <view class="actions" wx:if="{{canComplete}}">
    <button class="btn btn-primary" bindtap="doComplete">确认完成</button>
  </view>
  <view class="actions" wx:if="{{canCancel}}">
    <button class="btn btn-outline" bindtap="doCancel">取消订单</button>
  </view>
  <view class="actions" wx:if="{{canReview}}">
    <button class="btn btn-primary" bindtap="goReview">去评价</button>
  </view>
</view>
