.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.detail-owner {
  background: linear-gradient(180deg, #fff8ef 0%, #f7f8fb 100%);
}

.detail-feeder {
  background: linear-gradient(180deg, #eef7ff 0%, #f4f7fb 100%);
}

.detail-hero {
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.06);
}

.hero-owner {
  background: linear-gradient(135deg, #fff3e2 0%, #ffe1bf 100%);
}

.hero-feeder {
  background: linear-gradient(135deg, #e0f2fe 0%, #c7e7ff 100%);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 14rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.65);
  color: #475569;
  font-size: 22rpx;
  font-weight: 600;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.page-desc {
  font-size: 25rpx;
  line-height: 1.6;
  color: #475569;
}

.detail-card {
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  background: rgba(255,255,255,0.94);
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.05);
}

.detail-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1px solid #f1f5f9;
  font-size: 28rpx;
  color: #1f2937;
}

.detail-row:last-child {
  border-bottom: none;
}

.dl {
  color: #94a3b8;
  width: 160rpx;
  flex-shrink: 0;
}

.actions {
  margin-top: 32rpx;
}

.actions .btn {
  margin-bottom: 16rpx;
  border-radius: 18rpx;
}
