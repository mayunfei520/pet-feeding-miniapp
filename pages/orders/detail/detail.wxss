/* ========== 订单详情 ========== */
.detail-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.hero-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.hero-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 14rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.7);
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}

.page-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1A1A1A;
}

/* ===== 状态横幅 ===== */
.status-banner {
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}
.status-banner-pending    { background: #FFFBEB; color: #92400E; }
.status-banner-accepted   { background: #EFF6FF; color: #1E40AF; }
.status-banner-inprogress { background: #EFF6FF; color: #1E40AF; }
.status-banner-completed  { background: #F0FDF4; color: #166534; }
.status-banner-cancelled  { background: #FEF2F2; color: #991B1B; }

/* ===== 详情分组卡片 ===== */
.detail-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.detail-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1px solid #EEEEEE;
  font-size: 28rpx;
  color: #1A1A1A;
}
.detail-row:last-child {
  border-bottom: none;
}

.dl {
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}

.dv {
  flex: 1;
  color: #1A1A1A;
}
.dv.price {
  color: #F97316;
  font-weight: 500;
  font-size: 32rpx;
}

/* ===== 操作区 ===== */
.actions {
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}
.actions .btn {
  margin-bottom: 16rpx;
}
