/* ========== 订单详情 ========== */
.detail-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.hero-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.hero-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 14rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.7);
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}

.page-title {
  font-size: 34rpx;
  font-weight: 500;
  color: #1A1A1A;
}

/* ===== 状态横幅 ===== */
.status-banner {
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  margin-bottom: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}
.status-banner-pending    { background: #FFFBEB; color: #92400E; }
.status-banner-accepted   { background: #EFF6FF; color: #1E40AF; }
.status-banner-inprogress { background: #EFF6FF; color: #1E40AF; }
.status-banner-completed  { background: #F0FDF4; color: #166534; }
.status-banner-cancelled  { background: #FEF2F2; color: #991B1B; }

/* ===== 详情分组卡片 ===== */
.detail-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}

.detail-row {
  display: flex;
  padding: 18rpx 0;
  border-bottom: 1px solid #EEEEEE;
  font-size: 28rpx;
  color: #1A1A1A;
}
.detail-row:last-child {
  border-bottom: none;
}

.dl {
  color: #999999;
  width: 160rpx;
  flex-shrink: 0;
}

.dv {
  flex: 1;
  color: #1A1A1A;
}
.dv.price {
  color: #F97316;
  font-weight: 500;
  font-size: 32rpx;
}

/* ===== 操作区 ===== */
.actions {
  margin-top: 32rpx;
  padding-bottom: 40rpx;
}
.actions .btn {
  margin-bottom: 16rpx;
}

/* ===== 流程进度步骤条 ===== */
.flow {
  display: flex;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.flow-step {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}
.flow-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #F0E6DC;
  color: #B8A99C;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  border: 4rpx solid #FFFFFF;
  box-sizing: border-box;
}
.flow-step.done .flow-dot {
  background: #F97316;
  color: #FFFFFF;
}
.flow-step.active .flow-dot {
  background: #FB923C;
  color: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(249,115,22,0.18);
}
.flow-label {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #8A7F78;
  line-height: 1.3;
}
.flow-step.done .flow-label,
.flow-step.active .flow-label {
  color: #EA580C;
  font-weight: 500;
}
.flow-line {
  position: absolute;
  top: 24rpx;
  left: 50%;
  width: 100%;
  height: 4rpx;
  background: #F0E6DC;
  z-index: 1;
}
.flow-line.done {
  background: #F97316;
}

/* ===== 主人等待报价提示 ===== */
.await-hint {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #FFEDD5;
}
.await-icon {
  font-size: 40rpx;
  line-height: 1;
}
.await-text {
  flex: 1;
  display: flex;
  flex-direction: column;
}
.await-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #C2410C;
  margin-bottom: 6rpx;
}
.await-sub {
  font-size: 24rpx;
  color: #9A3412;
  line-height: 1.5;
}

/* 已报价横幅暖色 */
.status-banner-quoted { background: #FFF7ED; color: #C2410C; }
