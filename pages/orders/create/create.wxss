/* ========== 创建订单 ========== */
.order-page {
  padding: 24rpx;
  min-height: 100vh;
  background: #F5F5F5;
  box-sizing: border-box;
}

.header-bar {
  margin-bottom: 24rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.field {
  margin-bottom: 32rpx;
}
.field:last-child { margin-bottom: 0; }

.field-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}
.label-icon { font-size: 26rpx; }
.required { color: #EF4444; }

.picker-box {
  padding: 24rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1A1A1A;
}
.picker-box::after {
  content: ' >';
  float: right;
  color: #999999;
}
.empty-pick {
  color: #F97316;
  text-align: center;
}

.feeder-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}
.feeder-opt {
  flex-shrink: 0;
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #f9fafb;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
  position: relative;
}
.feeder-opt.active {
  border-color: #F97316;
  background: #FFF7ED;
}
.feeder-opt-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #F97316;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}
.feeder-opt-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}
.feeder-opt-area {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 4rpx;
}
.feeder-opt-rating {
  font-size: 24rpx;
  color: #F59E0B;
}
.feeder-check {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #F97316;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.period-group {
  display: flex;
  gap: 16rpx;
}
.period {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: #f9fafb;
  border: 2rpx solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666666;
}
.period.active {
  background: #FFF7ED;
  border-color: #F97316;
  color: #F97316;
  font-weight: 500;
}
.period-icon { font-size: 32rpx; }

.field-input {
  width: 100%;
  padding: 24rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 1.4;
}
.field-input:focus {
  border-color: #F97316;
  background: #FFFFFF;
}

.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  line-height: 1.6;
}
.field-textarea:focus {
  border-color: #F97316;
  background: #FFFFFF;
}

.empty-inline {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}
