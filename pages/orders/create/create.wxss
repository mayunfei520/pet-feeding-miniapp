/* ========== 页面容器 ========== */
.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f3f4f6;
}
.header-bar {
  margin-bottom: 24rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

/* ========== 表单卡片 ========== */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.field {
  margin-bottom: 32rpx;
}
.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}
.label-icon {
  font-size: 26rpx;
}
.required {
  color: #ef4444;
  font-weight: 400;
}

/* 选择器 */
.picker-box {
  padding: 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
}
.picker-box::after {
  content: ' ›';
  float: right;
  color: #9ca3af;
}
.empty-pick {
  color: #3b82f6;
  text-align: center;
}

/* ========== 喂养员选择卡片 ========== */
.feeder-grid {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}
.feeder-opt {
  flex-shrink: 0;
  width: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  position: relative;
  transition: all 0.2s;
}
.feeder-opt.active {
  border-color: #3b82f6;
  background: #eff6ff;
}
.feeder-opt-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}
.feeder-opt-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}
.feeder-opt-area {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 4rpx;
}
.feeder-opt-rating {
  font-size: 24rpx;
  color: #f59e0b;
}
.feeder-check {
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #3b82f6;
  color: #fff;
  font-size: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-inline {
  text-align: center;
  padding: 40rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
}

/* ========== 时段 ========== */
.period-group {
  display: flex;
  gap: 16rpx;
}
.period {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 20rpx 0;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #6b7280;
  transition: all 0.2s;
}
.period.active {
  background: #eff6ff;
  border-color: #3b82f6;
  color: #3b82f6;
  font-weight: 600;
}
.period-icon {
  font-size: 32rpx;
}

/* ========== 输入框 ========== */
.field-input {
  width: 100%;
  padding: 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 1.4;
}
.field-input:focus {
  border-color: #3b82f6;
  background: #fff;
}
.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  line-height: 1.6;
}
.field-textarea:focus {
  border-color: #3b82f6;
  background: #fff;
}

/* ========== 提交按钮 ========== */
.save-bar {
  padding: 8rpx 0 40rpx;
}
.save-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.35);
  transition: all 0.2s;
}
.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
