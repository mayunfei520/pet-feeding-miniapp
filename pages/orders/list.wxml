<!-- 订单列表（TabBar 页面） -->
<view class="orders-page">
  <view class="{{headerCardClass}}">
    <view class="role-badge">{{roleBadgeText}}</view>
    <view class="page-title">{{pageTitle}}</view>
    <view class="page-desc">{{pageDesc}}</view>
  </view>

  <view class="tabs">
    <view class="{{tabAllClass}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="{{tabPendingClass}}" bindtap="switchTab" data-tab="pending">待处理</view>
    <view class="{{tabDoneClass}}" bindtap="switchTab" data-tab="done">已完成</view>
  </view>

  <view wx:if="{{error}}" class="empty">{{error}}</view>

  <view wx:for="{{filteredOrders}}" wx:key="id" class="card order-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="oc-top">
      <text class="oc-no">{{item.orderNo}}</text>
      <view class="{{item.tagClass}}">
        {{statusMap[item.status]}}
      </view>
    </view>
    <view class="oc-info">
      <text>📅 {{item.serviceDate}} {{periodMap[item.servicePeriod]}}</text>
      <text>📍 {{item.address}}</text>
      <text>💰 ¥{{item.price}}</text>
    </view>
    <view class="oc-actions">
      <button class="btn-sm primary" wx:if="{{item.canFeederAccept}}" catchtap="doAccept" data-id="{{item.id}}">接单</button>
      <button class="btn-sm primary" wx:if="{{item.canFeederStart}}" catchtap="doStart" data-id="{{item.id}}">开始服务</button>
      <button class="btn-sm primary" wx:if="{{item.canOwnerComplete}}" catchtap="doComplete" data-id="{{item.id}}">确认完成</button>
      <button class="btn-sm danger" wx:if="{{item.canCancel}}" catchtap="doCancel" data-id="{{item.id}}">取消</button>
      <button class="btn-sm primary" wx:if="{{item.canOwnerReview}}" catchtap="goReview" data-id="{{item.id}}">评价</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{filteredOrders.length === 0}}" class="empty">暂无订单</view>
</view>
