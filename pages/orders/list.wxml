<!-- 订单列表（TabBar 页面） -->
<view class="container">
  <view class="tabs">
    <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部</view>
    <view class="tab {{activeTab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">进行中</view>
    <view class="tab {{activeTab === 'done' ? 'active' : ''}}" bindtap="switchTab" data-tab="done">已完成</view>
  </view>

  <view wx:for="{{filteredOrders}}" wx:key="id" class="card order-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="oc-top">
      <text class="oc-no">{{item.orderNo}}</text>
      <view class="tag tag-{{item.status === 'PENDING' ? 'pending' : item.status === 'COMPLETED' ? 'completed' : 'accepted'}}">
        {{statusMap[item.status]}}
      </view>
    </view>
    <view class="oc-info">
      <text>📅 {{item.serviceDate}} {{periodMap[item.servicePeriod]}}</text>
      <text>📍 {{item.address}}</text>
      <text>💰 ¥{{item.price}}</text>
    </view>
    <view class="oc-actions" wx:if="{{item.status === 'ACCEPTED' && role === 'OWNER'}}">
      <button class="btn-sm" bindtap="doComplete" data-id="{{item.id}}">确认完成</button>
    </view>
    <view class="oc-actions" wx:if="{{item.status === 'PENDING'}}">
      <button class="btn-sm danger" bindtap="doCancel" data-id="{{item.id}}">取消</button>
    </view>
    <view class="oc-actions" wx:if="{{item.status === 'COMPLETED' && role === 'OWNER'}}">
      <button class="btn-sm primary" bindtap="goReview" data-id="{{item.id}}">评价</button>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{error}}" class="empty">{{error}}</view>
  <view wx:elif="{{filteredOrders.length === 0}}" class="empty">暂无订单</view>
</view>
