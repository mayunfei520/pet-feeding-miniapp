/* ========== 登录页 — 暖橙主题 ========== */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF7ED 0%, #FFEDD5 50%, #FFF8F1 100%);
}

.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 0;
}

.logo-area {
  margin-bottom: 48rpx;
  text-align: center;
}

.logo-text {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  display: block;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #EA580C;
}

.app-slogan {
  font-size: 26rpx;
  color: #9A3412;
  opacity: 0.7;
  margin-top: 8rpx;
}

.tab-bar {
  display: flex;
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  margin-bottom: 40rpx;
  padding: 4rpx;
  width: 100%;
}

.tab {
  flex: 1;
  padding: 20rpx 0;
  color: #999999;
  font-size: 32rpx;
  border-radius: 8rpx;
  text-align: center;
  transition: all 0.2s;
}

.tab.active {
  background: #F97316;
  color: #fff;
  font-weight: 500;
}

.form {
  width: 100%;
}

.register-notice {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #FFF7ED;
  color: #EA580C;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 28rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1px solid #E5E7EB;
}
.login-input:focus {
  border-color: #F97316;
}

/* 性别分段（选填，暖橙胶囊） */
.gender-block { margin-bottom: 24rpx; }
.gender-label {
  font-size: 26rpx;
  color: #8A7B72;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}
.gender-optional { color: #B8A89E; font-size: 22rpx; }
.gender-seg { display: flex; gap: 20rpx; }
.gender-opt {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  font-size: 30rpx;
  color: #6B5D54;
  background: #FFFFFF;
  border: 2rpx solid #F0E2D6;
  border-radius: 42rpx;
  box-shadow: 0 2rpx 8rpx rgba(249,115,22,0.04);
  transition: all .2s ease;
}
.gender-opt--on {
  color: #FFFFFF;
  background: #F97316;
  border-color: #F97316;
  box-shadow: 0 4rpx 14rpx rgba(249,115,22,0.28);
  font-weight: 600;
}

.code-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}
.code-input {
  flex: 1;
  margin-bottom: 0;
}
.code-btn {
  flex-shrink: 0;
  width: 220rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #fff;
  color: #F97316;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 12rpx;
  line-height: 1;
  border: 1px solid #F97316;
}
.code-btn::after { border: none; }
.code-btn:active { background: #FFF7ED; }
.code-btn[disabled] {
  color: #BBBBBB;
  border-color: #E5E7EB;
  background: #F5F5F5;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #F97316;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  line-height: 1;
  margin-top: 12rpx;
  border: none;
}
.login-btn::after { border: none; }
.login-btn:active { background: #EA580C; }

.switch-link {
  text-align: center;
  color: #999999;
  font-size: 26rpx;
  margin-top: 32rpx;
  margin-bottom: 24rpx;
}

.divider-row {
  display: flex;
  align-items: center;
  margin: 32rpx 0 24rpx;
  gap: 16rpx;
}
.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E5E7EB;
}
.divider-text {
  font-size: 24rpx;
  color: #999999;
  flex-shrink: 0;
}

.phone-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #fff;
  color: #07C160;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 12rpx;
  line-height: 1;
  border: 1px solid #07C160;
  margin-top: 0;
}
.phone-btn::after { border: none; }
.phone-btn:active { background: #F0FFF4; }
.phone-btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}
