/* ========== 登录页 — 暖橙主题 ========== */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFF7ED 0%, #FFEDD5 50%, #F5F5F5 100%);
}

.login-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx 0;
}

.logo-area {
  margin-bottom: 48rpx;
  text-align: center;
}

.logo-text {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  display: block;
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #EA580C;
}

.app-slogan {
  font-size: 26rpx;
  color: #9A3412;
  opacity: 0.7;
  margin-top: 8rpx;
}

.tab-bar {
  display: flex;
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  margin-bottom: 40rpx;
  padding: 4rpx;
  width: 100%;
}

.tab {
  flex: 1;
  padding: 20rpx 0;
  color: #999999;
  font-size: 32rpx;
  border-radius: 8rpx;
  text-align: center;
  transition: all 0.2s;
}

.tab.active {
  background: #F97316;
  color: #fff;
  font-weight: 500;
}

.form {
  width: 100%;
}

.register-notice {
  margin-bottom: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #FFF7ED;
  color: #EA580C;
  font-size: 24rpx;
  line-height: 1.6;
}

.login-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 28rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1px solid #E5E7EB;
}
.login-input:focus {
  border-color: #F97316;
}

.login-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  background: #F97316;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 12rpx;
  line-height: 1;
  margin-top: 12rpx;
  border: none;
}
.login-btn::after { border: none; }
.login-btn:active { background: #EA580C; }

.switch-link {
  text-align: center;
  color: #999999;
  font-size: 26rpx;
  margin-top: 32rpx;
  margin-bottom: 24rpx;
}
