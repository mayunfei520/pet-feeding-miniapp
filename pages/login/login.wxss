page { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh; }
.login-box { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx 0; }
.logo { font-size: 120rpx; margin-bottom: 20rpx; }
.title { font-size: 48rpx; color: #fff; font-weight: bold; margin-bottom: 60rpx; }
.tab-bar { display: flex; background: rgba(255,255,255,0.2); border-radius: 16rpx; margin-bottom: 40rpx; }
.tab { padding: 20rpx 60rpx; color: rgba(255,255,255,0.7); font-size: 32rpx; border-radius: 16rpx; }
.tab.active { background: #fff; color: #667eea; font-weight: bold; }
.form { width: 100%; }
.register-notice { margin-bottom: 20rpx; padding: 18rpx 20rpx; border-radius: 16rpx; background: rgba(255,255,255,0.18); color: rgba(255,255,255,0.92); font-size: 24rpx; line-height: 1.6; }
.input { width: 100%; height: 88rpx; background: rgba(255,255,255,0.95); border-radius: 16rpx; padding: 0 30rpx; margin-bottom: 24rpx; font-size: 28rpx; box-sizing: border-box; }
.btn-primary { width: 100%; height: 88rpx; display: flex; align-items: center; justify-content: center; padding: 0; background: #fff; color: #667eea; font-size: 32rpx; font-weight: bold; border-radius: 16rpx; line-height: 1; margin-top: 20rpx; }
.btn-primary::after { border: none; }
.switch-link { text-align: center; color: rgba(255,255,255,0.8); font-size: 26rpx; margin-top: 30rpx; }
