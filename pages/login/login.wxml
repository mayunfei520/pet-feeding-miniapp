<!-- 登录/注册 -->
<view class="login-page">
  <view class="login-box">
    <view class="logo-area">
      <text class="logo-text">🐾</text>
      <view class="app-name">宠物喂养</view>
      <view class="app-slogan">让每一次出行都安心</view>
    </view>

    <view class="tab-bar">
      <view class="{{loginTabClass}}" bindtap="switchTab">登录</view>
      <view class="{{registerTabClass}}" bindtap="switchTab">注册</view>
    </view>

    <view class="form" wx:if="{{!isRegister}}">
      <input class="login-input" placeholder="手机号" type="number" maxlength="11" bindinput="onPhoneInput" />
      <view class="pwd-wrap">
        <input class="login-input pwd-input" placeholder="密码" type="{{showPassword ? 'text' : 'password'}}" bindinput="onPasswordInput" />
        <view class="eye" bindtap="togglePassword">{{showPassword ? '👁' : '🙈'}}</view>
      </view>
      <button class="login-btn" bindtap="doLogin">登录</button>
      <view class="switch-link" bindtap="switchTab">没有账号？去注册</view>
    </view>

    <view class="form" wx:else>
      <view class="register-notice">{{registerNotice}}</view>
      <input class="login-input" placeholder="手机号" type="number" maxlength="11" bindinput="onPhoneInput" />
      <input class="login-input" placeholder="真实姓名（2-4个汉字）" maxlength="8" value="{{realName}}" bindinput="onRealNameInput" />
      <view class="pwd-wrap">
        <input class="login-input pwd-input" placeholder="密码（8-20位，含大小写字母+数字）" type="{{showPassword ? 'text' : 'password'}}" bindinput="onPasswordInput" />
        <view class="eye" bindtap="togglePassword">{{showPassword ? '👁' : '🙈'}}</view>
      </view>
      <view class="pwd-bar" wx:if="{{passwordHint}}">
        <view class="pwd-bar-fill pwd-bar-{{pwdStrength}}"></view>
      </view>
      <view class="pwd-hint {{passwordValid ? 'ok' : 'bad'}}" wx:if="{{passwordHint}}">{{passwordHint}}</view>
      <view class="gender-block">
        <view class="gender-label">性别<text class="gender-optional">（选填）</text></view>
        <view class="gender-seg">
          <view class="gender-opt {{gender === '女' ? 'gender-opt--on' : ''}}" bindtap="onGenderTap" data-g="女">女</view>
          <view class="gender-opt {{gender === '男' ? 'gender-opt--on' : ''}}" bindtap="onGenderTap" data-g="男">男</view>
        </view>
      </view>
      <view class="code-row">
        <input class="login-input code-input" placeholder="验证码" type="number" maxlength="6" value="{{code}}" bindinput="onCodeInput" />
        <button class="code-btn" bindtap="sendCode" disabled="{{codeCountown > 0}}">{{codeBtnText}}</button>
      </view>
      <button class="login-btn" bindtap="doRegister">注册平台账号</button>
      <view class="switch-link" bindtap="switchTab">已有账号？去登录</view>
    </view>
  </view>
</view>
