<view class="page">
  <view class="login-box">
    <view class="logo">🐾</view>
    <view class="title">宠物喂养平台</view>
    <view class="tab-bar">
      <view class="{{loginTabClass}}" bindtap="switchTab">登录</view>
      <view class="{{registerTabClass}}" bindtap="switchTab">注册</view>
    </view>
    <view class="form" wx:if="{{!isRegister}}">
      <input class="input" placeholder="手机号" maxlength="11" bindinput="onPhoneInput" />
      <input class="input" placeholder="密码" type="password" bindinput="onPasswordInput" />
      <button class="btn-primary" bindtap="doLogin">登录</button>
      <view class="switch-link" bindtap="switchTab">没有账号？去注册</view>
    </view>
    <view class="form" wx:else>
      <view class="register-notice">{{registerNotice}}</view>
      <input class="input" placeholder="手机号" maxlength="11" bindinput="onPhoneInput" />
      <input class="input" placeholder="昵称（选填）" bindinput="onNicknameInput" />
      <input class="input" placeholder="密码（6位以上）" type="password" bindinput="onPasswordInput" />
      <button class="btn-primary" bindtap="doRegister">注册平台账号</button>
      <view class="switch-link" bindtap="switchTab">已有账号？去登录</view>
    </view>
  </view>
</view>
