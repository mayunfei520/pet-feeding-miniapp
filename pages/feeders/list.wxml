<!-- 喂养员列表 -->
<view class="page {{pageTheme}}">
  <view class="{{headerCardClass}}">
    <view class="role-badge">{{roleBadgeText}}</view>
    <text class="title">{{pageTitle}}</text>
    <text class="sub">{{pageDesc}}</text>
  </view>

  <view wx:for="{{feeders}}" wx:key="id" class="card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="card-left">
      <view class="avatar">{{item.avatarText}}</view>
    </view>
    <view class="card-body">
      <view class="row">
        <text class="name">{{item.realName}}</text>
        <view class="rating-badge">⭐ {{item.ratingText}}</view>
      </view>
      <view class="area">📍 {{item.serviceArea}}</view>
      <view class="desc" wx:if="{{item.description}}">{{item.description}}</view>
    </view>
    <view class="card-right">
      <text class="arrow">›</text>
    </view>
  </view>

  <view wx:if="{{loading}}" class="empty">
    <text class="empty-icon">⏳</text>
    <text>加载中...</text>
  </view>
  <view wx:elif="{{error}}" class="empty">
    <text class="empty-icon">😿</text>
    <text>{{error}}</text>
  </view>
  <view wx:elif="{{feeders.length === 0}}" class="empty">
    <text class="empty-icon">👤</text>
    <text class="empty-title">暂无喂养员</text>
    <text class="empty-desc">稍后再来看看</text>
  </view>
</view>
