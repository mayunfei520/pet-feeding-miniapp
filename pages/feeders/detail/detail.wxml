<!-- 喂养员详情 -->
<view class="feeder-page">
  <view class="{{heroClass}}">
    <view class="hero-avatar">{{feeder.avatarText}}</view>
    <view class="hero-body">
      <view class="role-badge">{{roleBadgeText}}</view>
      <view class="hero-name">{{feeder.realName}}</view>
      <view class="hero-area">📍 {{feeder.serviceArea}}</view>
      <view class="hero-rating">⭐ {{feeder.ratingText}}</view>
    </view>
  </view>

  <view class="card info-block" wx:if="{{feeder.experience || feeder.description}}">
    <view class="info-row" wx:if="{{feeder.experience}}">
      <text class="info-label">💼 经验</text>
      <text class="info-text">{{feeder.experience}}</text>
    </view>
    <view class="info-row" wx:if="{{feeder.description}}">
      <text class="info-label">📝 简介</text>
      <text class="info-text">{{feeder.description}}</text>
    </view>
  </view>

  <view class="action-bar" wx:if="{{showPrimaryAction}}">
    <view class="action-hint">{{actionHint}}</view>
    <view class="action-row">
      <button wx:if="{{showChat}}" class="action-btn ghost" bindtap="goChat">💬 沟通</button>
      <button class="action-btn primary" bindtap="goOrder">{{actionText}}</button>
    </view>
  </view>

  <view class="section-title">🌟 用户评价 ({{reviews.length}})</view>
  <view wx:for="{{reviews}}" wx:key="id" class="card review-card">
    <view class="review-top">
      <view class="review-stars">{{item.starText}}</view>
      <text class="review-date">{{item.dateText}}</text>
    </view>
    <view class="review-content">{{item.content}}</view>
  </view>
  <view wx:if="{{reviews.length === 0}}" class="empty">
    <text class="empty-icon">💬</text>
    <text>暂无评价</text>
  </view>

  <view class="save-bar" wx:if="{{showBottomAction}}">
    <button class="save-btn" bindtap="goOrder">{{bottomActionText}}</button>
  </view>
</view>
