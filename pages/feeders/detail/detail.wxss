/* ========== 页面容器 ========== */
.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f3f4f6;
}

.feeder-detail-owner {
  background: linear-gradient(180deg, #fff8ef 0%, #f7f8fb 100%);
}

.feeder-detail-feeder {
  background: linear-gradient(180deg, #eef7ff 0%, #f4f7fb 100%);
}

.feeder-detail-admin {
  background: linear-gradient(180deg, #eff1f5 0%, #f8fafc 100%);
}

/* ========== 喂养员名片 ========== */
.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.05);
}

.hero-owner {
  background: linear-gradient(135deg, #fff3e2 0%, #ffe1bf 100%);
}

.hero-feeder {
  background: linear-gradient(135deg, #e0f2fe 0%, #c7e7ff 100%);
}

.hero-admin {
  background: linear-gradient(135deg, #e5e7eb 0%, #d1d5db 100%);
}
.hero-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #fb923c, #f59e0b);
  color: #fff;
  font-size: 48rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(251, 146, 60, 0.25);
}

.feeder-detail-feeder .hero-avatar {
  background: linear-gradient(135deg, #0ea5e9, #2563eb);
  box-shadow: 0 8rpx 20rpx rgba(14, 165, 233, 0.25);
}

.feeder-detail-admin .hero-avatar {
  background: linear-gradient(135deg, #64748b, #334155);
  box-shadow: 0 8rpx 20rpx rgba(71, 85, 105, 0.2);
}
.hero-body {
  flex: 1;
  min-width: 0;
}
.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 10rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,0.65);
  color: #475569;
  font-size: 22rpx;
  font-weight: 600;
}
.hero-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.hero-area {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
}
.hero-rating {
  font-size: 28rpx;
  color: #f59e0b;
  font-weight: 600;
}

/* ========== 信息块 ========== */
.info-block {
  background: rgba(255,255,255,0.94);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 14rpx 34rpx rgba(15, 23, 42, 0.05);
}
.info-row {
  margin-bottom: 18rpx;
}
.info-row:last-child {
  margin-bottom: 0;
}
.info-label {
  display: block;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}
.info-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.6;
}

/* ========== 快捷操作 ========== */
.action-bar {
  margin-bottom: 24rpx;
}
.action-hint {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  text-align: center;
}
.action-btn.primary {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  color: #fff;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

/* ========== 评价 ========== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 16rpx;
}
.review-card {
  background: rgba(255,255,255,0.94);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 12rpx 24rpx rgba(15, 23, 42, 0.04);
}
.review-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.review-stars {
  color: #f59e0b;
  font-size: 24rpx;
}
.review-date {
  color: #9ca3af;
  font-size: 24rpx;
}
.review-content {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.7;
}

/* ========== 底部操作 ========== */
.save-bar {
  padding: 24rpx 0 40rpx;
}
.save-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(16, 185, 129, 0.35);
  transition: all 0.2s;
}

.feeder-detail-admin .save-btn {
  background: linear-gradient(135deg, #64748b, #334155);
}
.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
}
.empty-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
  opacity: 0.5;
}
