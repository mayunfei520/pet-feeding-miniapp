/* ========== 喂养员详情 ========== */
.feeder-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.hero-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  border-radius: 16rpx;
  padding: 36rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.hero-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.hero-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}
.hero-admin {
  background: linear-gradient(135deg, #F5F5F5, #E5E7EB);
}

.hero-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 32rpx;
  background: #F97316;
  color: #fff;
  font-size: 48rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.2);
}
.hero-body { flex: 1; min-width: 0; }
.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 10rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.7);
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}
.hero-name { font-size: 38rpx; font-weight: 500; color: #1A1A1A; margin-bottom: 8rpx; }
.hero-area { font-size: 26rpx; color: #666666; margin-bottom: 6rpx; }
.hero-rating { font-size: 28rpx; color: #F59E0B; font-weight: 500; }

.info-block {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.info-row { margin-bottom: 18rpx; }
.info-row:last-child { margin-bottom: 0; }
.info-label { display: block; font-size: 24rpx; color: #999999; margin-bottom: 6rpx; }
.info-text { font-size: 28rpx; color: #1A1A1A; line-height: 1.6; }

.action-bar { margin-bottom: 24rpx; }
.action-hint {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
  text-align: center;
}
.action-btn.primary {
  width: 100%;
  padding: 24rpx;
  background: #F97316;
  color: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(249,115,22,0.25);
}

.section-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.review-card {
  background: #FFFFFF;
  border-radius: 8rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.03);
}
.review-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}
.review-stars { color: #F59E0B; font-size: 24rpx; }
.review-date { color: #999999; font-size: 24rpx; }
.review-content { font-size: 28rpx; color: #1A1A1A; line-height: 1.7; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
  color: #999999;
  font-size: 26rpx;
}
.empty-icon { font-size: 48rpx; margin-bottom: 12rpx; opacity: 0.5; }
