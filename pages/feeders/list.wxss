/* ========== 喂养员列表 ========== */
.feeders-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.05);
}
.header-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.header-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}
.header-admin {
  background: linear-gradient(135deg, #F5F5F5, #E5E7EB);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  margin-bottom: 14rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.7);
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}
.sub {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.feeder-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.feeder-card:active {
  transform: scale(0.985);
}

.card-left { margin-right: 20rpx; flex-shrink: 0; }
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: #F97316;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-body { flex: 1; min-width: 0; }
.row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.name { font-size: 30rpx; font-weight: 500; color: #1A1A1A; }
.rating-badge {
  font-size: 24rpx;
  color: #F59E0B;
  background: #FFFBEB;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}
.area { font-size: 24rpx; color: #666666; margin-bottom: 6rpx; }
.desc { font-size: 24rpx; color: #999999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.card-right { flex-shrink: 0; margin-left: 12rpx; }
.arrow { font-size: 44rpx; color: #D1D5DB; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.6; }
.empty-title { font-size: 30rpx; color: #666666; font-weight: 500; margin-bottom: 8rpx; }
.empty-desc { font-size: 26rpx; color: #999999; }
