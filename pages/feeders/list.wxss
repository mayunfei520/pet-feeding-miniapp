/* ========== 喂养员列表 ========== */
.feeders-page {
  min-height: 100vh;
  background: #FFF8F1;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 10rpx;
}
.sub {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

.feeder-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.feeder-card:active {
  transform: scale(0.985);
}

.card-left { margin-right: 20rpx; flex-shrink: 0; }
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 28rpx;
  background: #F97316;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-body { flex: 1; min-width: 0; }
.row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 6rpx; }
.name { font-size: 30rpx; font-weight: 500; color: #1A1A1A; }
.rating-badge {
  font-size: 24rpx;
  color: #F59E0B;
  background: #FFFBEB;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
}
.area { font-size: 24rpx; color: #666666; margin-bottom: 6rpx; }
.desc { font-size: 24rpx; color: #999999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.card-right { flex-shrink: 0; margin-left: 12rpx; }
.arrow { font-size: 44rpx; color: #D1D5DB; }
