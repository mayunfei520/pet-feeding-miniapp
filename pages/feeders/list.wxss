/* ========== 页面容器 ========== */
.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f3f4f6;
}
.header-bar {
  margin-bottom: 24rpx;
}
.title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.sub {
  font-size: 26rpx;
  color: #9ca3af;
}

/* ========== 喂养员卡片 ========== */
.card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  transition: transform 0.15s;
}
.card:active {
  transform: scale(0.985);
}

/* 头像 */
.card-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 信息 */
.card-body {
  flex: 1;
  min-width: 0;
}
.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}
.name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}
.rating-badge {
  font-size: 24rpx;
  color: #f59e0b;
  background: #fef3c7;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.area {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 6rpx;
}
.desc {
  font-size: 24rpx;
  color: #9ca3af;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 箭头 */
.card-right {
  flex-shrink: 0;
  margin-left: 12rpx;
}
.arrow {
  font-size: 44rpx;
  color: #d1d5db;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}
.empty-title {
  font-size: 30rpx;
  color: #6b7280;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
}
