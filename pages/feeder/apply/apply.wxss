/* ========== 申请成为喂养员 ========== */
.apply-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.apply-hero {
  padding: 30rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.1);
  margin-bottom: 22rpx;
}

.apply-kicker {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.6);
  color: #9A3412;
  font-size: 20rpx;
  font-weight: 500;
  margin-bottom: 14rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 500;
  color: #7C2D12;
  margin-bottom: 14rpx;
}

.apply-subtitle {
  font-size: 25rpx;
  line-height: 1.7;
  color: #9A3412;
}

.steps-card,
.form {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.steps-card { margin-bottom: 22rpx; }

.steps-title,
.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 18rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}
.step-item + .step-item { margin-top: 18rpx; }

.step-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F97316;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.step-name {
  font-size: 27rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 6rpx;
}

.step-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.6;
}

.form-item { margin-bottom: 24rpx; }

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.required { color: #EF4444; }

.apply-input {
  width: 100%;
  min-height: 88rpx;
  padding: 0 26rpx;
  border-radius: 8rpx;
  background: #f8fafc;
  border: 1px solid #E5E7EB;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1A1A1A;
}
.apply-input:focus { border-color: #F97316; background: #FFFFFF; }

.apply-textarea {
  min-height: 160rpx;
  padding: 20rpx 26rpx;
}

.submit-btn {
  margin-top: 10rpx;
  border-radius: 8rpx;
  background: #F97316;
  color: #fff;
}
.submit-btn::after { border: none; }
.submit-btn:active { background: #EA580C; }
