.banner { height: 320rpx; border-radius: 16rpx; overflow: hidden; margin-bottom: 24rpx; }
.banner-item {
  height: 100%; display: flex; align-items: center; justify-content: center;
}
.banner-text { color: #fff; font-size: 36rpx; font-weight: bold; }

.quick-nav { display: flex; justify-content: space-around; margin-bottom: 30rpx; }
.nav-item { display: flex; flex-direction: column; align-items: center; }
.nav-icon { font-size: 56rpx; margin-bottom: 8rpx; }
.nav-text { font-size: 24rpx; color: #6b7280; }

.section { margin-bottom: 30rpx; }
.section-title { font-size: 32rpx; font-weight: 600; margin-bottom: 16rpx; color: #111827; }

.feeder-scroll { white-space: nowrap; }
.feeder-card {
  display: inline-block; width: 220rpx; padding: 24rpx; background: #fff;
  border-radius: 12rpx; margin-right: 16rpx; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.feeder-name { font-size: 28rpx; font-weight: 600; margin-bottom: 6rpx; white-space: normal; }
.feeder-area { font-size: 24rpx; color: #6b7280; margin-bottom: 4rpx; white-space: normal; }
.feeder-rating { font-size: 24rpx; color: #f59e0b; }
