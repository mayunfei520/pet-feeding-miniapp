/* ========== 页面容器 ========== */
.page {
  padding: 0 24rpx 40rpx;
  min-height: 100vh;
  background: #f3f4f6;
}

/* ========== Banner ========== */
.banner {
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin: 20rpx 0 24rpx;
}
.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}
.banner-emoji {
  font-size: 80rpx;
  margin-right: 28rpx;
}
.banner-text-wrap {
  display: flex;
  flex-direction: column;
}
.banner-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}
.banner-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ========== 数据统计条 ========== */
.stats-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 4rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #9ca3af;
}

/* ========== 快捷服务 ========== */
.section {
  margin-bottom: 28rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 18rpx;
}
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.section-title-row .section-title {
  margin-bottom: 18rpx;
}
.section-more {
  font-size: 26rpx;
  color: #3b82f6;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}
.quick-text {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

/* ========== 推荐喂养员 ========== */
.feeder-scroll {
  white-space: nowrap;
  margin-left: -24rpx;
  padding-left: 24rpx;
  width: 100vw;
  box-sizing: border-box;
}
.feeder-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  padding: 28rpx 16rpx;
  background: #fff;
  border-radius: 18rpx;
  margin-right: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.feeder-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #8b5cf6);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.feeder-info {
  text-align: center;
  white-space: normal;
}
.feeder-card .feeder-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
}
.feeder-card .feeder-area {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 6rpx;
}
.feeder-card .feeder-rating {
  font-size: 24rpx;
  color: #f59e0b;
  margin-bottom: 6rpx;
}
.feeder-card .feeder-exp {
  font-size: 22rpx;
  color: #6b7280;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-inline {
  text-align: center;
  padding: 40rpx 0;
  color: #9ca3af;
  font-size: 26rpx;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}
.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}
