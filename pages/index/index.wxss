/* ========== 首页 ========== */
.page {
  padding: 0 24rpx 40rpx;
  min-height: 100vh;
  background: #FFF8F1;
}

/* ===== Banner ===== */
.banner {
  height: 300rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin: 20rpx 0 24rpx;
}
.banner-item {
  height: 100%;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
}
.banner-emoji {
  font-size: 80rpx;
  margin-right: 28rpx;
}
.banner-text-wrap {
  display: flex;
  flex-direction: column;
}
.banner-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}
.banner-sub {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

/* ===== 数据统计 ===== */
.stats-bar {
  display: flex;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #F97316;
  margin-bottom: 4rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* ===== 快捷入口 Hero Card ===== */
.hero-card {
  border-radius: 28rpx;
  padding: 28rpx 24rpx 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.10);
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #666666;
  background: rgba(255,255,255,0.7);
  margin-bottom: 18rpx;
}

.hero-desc {
  margin-bottom: 22rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #666666;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
}
.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 8rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.6);
}
.quick-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}
.quick-text {
  font-size: 24rpx;
  color: #1A1A1A;
  font-weight: 500;
  text-align: center;
}

/* ===== 分区 ===== */
.section {
  margin-bottom: 24rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 18rpx;
}
.section-title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}
.section-title-row .section-title {
  margin-bottom: 18rpx;
}
.section-more {
  font-size: 26rpx;
  color: #F97316;
}

/* ===== 推荐喂养员 ===== */
.feeder-scroll {
  white-space: nowrap;
  margin-left: -24rpx;
  padding-left: 24rpx;
  width: 100vw;
  box-sizing: border-box;
}
.feeder-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 200rpx;
  padding: 28rpx 16rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-right: 16rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.feeder-card:active {
  background: #f9f9f9;
}
.feeder-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #F97316;
  color: #fff;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}
.feeder-info {
  text-align: center;
  white-space: normal;
}
.feeder-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 4rpx;
}
.feeder-area {
  font-size: 22rpx;
  color: #999999;
  margin-bottom: 6rpx;
}
.feeder-rating {
  font-size: 24rpx;
  color: #F59E0B;
}
.feeder-exp {
  font-size: 22rpx;
  color: #666666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feeder-more-hint {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 100%;
  font-size: 24rpx;
  color: #999999;
  white-space: nowrap;
  padding-right: 24rpx;
}

.empty-inline {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}
