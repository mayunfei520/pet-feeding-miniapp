/* ========== 页头 ========== */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 4rpx;
}
.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

/* 添加按钮 */
.add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 28rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
  border-radius: 40rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
  transition: all 0.2s;
}
.add-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}
.add-icon {
  font-size: 32rpx;
  font-weight: 300;
  line-height: 1;
}

/* ========== 宠物卡片 ========== */
.pet-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: transform 0.15s;
}
.pet-card:active {
  transform: scale(0.985);
}

/* 头像 */
.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}
.avatar-emoji {
  font-size: 50rpx;
}

/* 宠物信息 */
.pet-body {
  flex: 1;
  min-width: 0;
  padding-right: 12rpx;
}
.pet-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.pet-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #111827;
}

/* 物种标签 */
.species-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  background: #eff6ff;
  color: #3b82f6;
  font-weight: 500;
}

/* 属性行 */
.pet-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 6rpx;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #6b7280;
}
.meta-icon {
  font-size: 22rpx;
}

/* 医疗备注 */
.pet-memo {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  font-size: 24rpx;
  color: #9ca3af;
  background: #fefce8;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  line-height: 1.5;
}
.memo-icon {
  flex-shrink: 0;
  font-size: 22rpx;
}

/* ========== 操作按钮 ========== */
.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  transition: all 0.15s;
}
.action-btn:active {
  transform: scale(0.9);
}
.action-btn.edit {
  background: #eff6ff;
}
.action-btn.edit:active {
  background: #dbeafe;
}
.action-btn.del {
  background: #fef2f2;
}
.action-btn.del:active {
  background: #fee2e2;
}

/* ========== 空状态 ========== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}
.empty-title {
  font-size: 30rpx;
  color: #6b7280;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
  margin-bottom: 32rpx;
}
.empty-add-btn {
  padding: 16rpx 48rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(59, 130, 246, 0.3);
}
.empty-add-btn:active {
  opacity: 0.85;
}
.retry-btn {
  margin-top: 20rpx;
  padding: 16rpx 48rpx;
  background: #fff;
  color: #3b82f6;
  border: 1px solid #93c5fd;
  border-radius: 40rpx;
  font-size: 28rpx;
}
