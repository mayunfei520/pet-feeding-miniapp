.header-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 20rpx; font-size: 34rpx; font-weight: 600;
}
.add-btn { padding: 12rpx 24rpx; background: #3b82f6; color: #fff; border-radius: 10rpx; font-size: 26rpx; border: none; }
.pet-card { display: flex; justify-content: space-between; align-items: center; }
.pet-name { font-size: 32rpx; font-weight: 600; margin-bottom: 6rpx; }
.pet-detail { font-size: 26rpx; color: #6b7280; }
.pet-memo { font-size: 24rpx; color: #9ca3af; margin-top: 6rpx; }
.pet-actions { display: flex; gap: 12rpx; }
.btn-sm { padding: 10rpx 20rpx; border-radius: 8rpx; font-size: 24rpx; border: 1px solid #d1d5db; background: #fff; }
.btn-sm.danger { color: #ef4444; border-color: #fca5a5; }
