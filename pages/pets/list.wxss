/* ========== 宠物列表 ========== */
.page {
  min-height: 100vh;
  background: #F5F5F5;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 24rpx 24rpx 0;
}
.title {
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.add-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 14rpx 28rpx;
  background: #F97316;
  color: #fff;
  border-radius: 9999rpx;
  font-size: 26rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(249,115,22,0.25);
}

.pet-list {
  padding: 0 24rpx;
}

.pet-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.pet-card:active {
  transform: scale(0.985);
}

.pet-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}
.avatar-emoji { font-size: 50rpx; }

.pet-body {
  flex: 1;
  min-width: 0;
}
.pet-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}
.pet-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.species-tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 9999rpx;
  background: #FFF7ED;
  color: #EA580C;
  font-weight: 500;
}

.pet-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 6rpx;
}
.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #666666;
}
.meta-icon { font-size: 22rpx; }

.pet-memo {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  font-size: 24rpx;
  color: #999999;
  background: #FEFCE8;
  padding: 8rpx 14rpx;
  border-radius: 10rpx;
  margin-top: 6rpx;
  line-height: 1.5;
}

.pet-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}
.action-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.action-btn.edit { background: #FFF7ED; }
.action-btn.del { background: #FEF2F2; }

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; opacity: 0.6; }
.empty-title { font-size: 30rpx; color: #666666; font-weight: 500; margin-bottom: 8rpx; }
.empty-desc { font-size: 26rpx; color: #999999; margin-bottom: 32rpx; }
.empty-add-btn {
  padding: 16rpx 48rpx;
  background: #F97316;
  color: #fff;
  border-radius: 9999rpx;
  font-size: 28rpx;
}
.retry-btn {
  margin-top: 20rpx;
  padding: 16rpx 48rpx;
  background: #FFFFFF;
  color: #F97316;
  border: 1px solid #F97316;
  border-radius: 9999rpx;
  font-size: 28rpx;
}
