<!-- 添加/编辑宠物 -->
<view class="add-page">
  <view class="preview-card">
    <view class="preview-avatar" style="{{previewAvatarStyle}}">
      <text class="preview-emoji">{{previewEmoji}}</text>
    </view>
    <view class="preview-info">
      <text class="preview-name">{{previewName}}</text>
      <text class="preview-meta">{{previewMeta}}</text>
    </view>
  </view>

  <view class="form-card">
    <view class="field">
      <view class="field-label">
        <text class="label-icon">📝</text>
        <text>名字</text>
        <text class="required">*</text>
      </view>
      <input class="field-input" placeholder="给宠物取个名字吧" value="{{form.name}}" bindinput="onInput" data-field="name" maxlength="20" />
    </view>

    <view class="field">
      <view class="field-label">
        <text class="label-icon">🏷️</text>
        <text>种类</text>
        <text class="required">*</text>
      </view>
      <view class="species-grid">
        <view wx:for="{{speciesOptions}}" wx:key="value" class="{{item.className}}" bindtap="selectSpecies" data-value="{{item.value}}">
          <text class="species-emoji">{{item.emoji}}</text>
          <text class="species-label">{{item.label}}</text>
          <view wx:if="{{form.species === item.value}}" class="species-check">✓</view>
        </view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">
        <text class="label-icon">🧬</text>
        <text>品种</text>
      </view>
      <input class="field-input" placeholder="如：英短、金毛、布偶…" value="{{form.breed}}" bindinput="onInput" data-field="breed" />
    </view>

    <view class="row-fields">
      <view class="field half">
        <view class="field-label">
          <text class="label-icon">🎂</text>
          <text>年龄</text>
        </view>
        <view class="input-with-unit">
          <input class="field-input" type="digit" placeholder="0" value="{{form.age}}" bindinput="onInput" data-field="age" />
          <text class="unit">岁</text>
        </view>
      </view>
      <view class="field half">
        <view class="field-label">
          <text class="label-icon">⚖️</text>
          <text>体重</text>
        </view>
        <view class="input-with-unit">
          <input class="field-input" type="digit" placeholder="0.0" value="{{form.weight}}" bindinput="onInput" data-field="weight" />
          <text class="unit">kg</text>
        </view>
      </view>
    </view>

    <view class="field">
      <view class="field-label">
        <text class="label-icon">💊</text>
        <text>医疗备注</text>
      </view>
      <textarea class="field-textarea" placeholder="过敏史、慢性病、饮食禁忌…" value="{{form.medicalNotes}}" bindinput="onInput" data-field="medicalNotes" maxlength="200" />
      <text class="field-hint">选填，帮助喂养员更好地照顾宠物</text>
    </view>
    <view class="field">
      <view class="field-label">
        <text class="label-icon">💉</text>
        <text>是否打疫苗</text>
      </view>
      <view class="switch-row">
        <text wx:if="{{!form.vaccinated}}" class="switch-text off">未打疫苗</text>
        <text wx:else class="switch-text on">已打疫苗</text>
        <switch checked="{{form.vaccinated}}" bindchange="toggleVaccinated" color="#F97316" />
      </view>
    </view>
  </view>

  <view class="save-bar">
    <button class="save-btn" bindtap="doSave">
      <text wx:if="{{editId}}">✏️ 更新宠物信息</text>
      <text wx:else>✨ 添加宠物</text>
    </button>
  </view>
</view>
