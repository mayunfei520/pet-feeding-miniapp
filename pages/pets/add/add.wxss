/* ========== 添加/编辑宠物 ========== */
.add-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  box-sizing: border-box;
}

.preview-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}
.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}
.preview-emoji { font-size: 60rpx; }
.preview-info { flex: 1; min-width: 0; }
.preview-name {
  display: block;
  font-size: 36rpx;
  font-weight: 500;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}
.preview-meta {
  display: block;
  font-size: 26rpx;
  color: #999999;
}

.form-card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
}

.field {
  margin-bottom: 32rpx;
}
.field:last-child { margin-bottom: 0; }

.field-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}
.label-icon { font-size: 26rpx; }
.required { color: #EF4444; margin-left: 2rpx; }

.field-input {
  width: 100%;
  padding: 22rpx 24rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 1.5;
}
.field-input:focus { border-color: #F97316; background: #FFFFFF; }

.input-with-unit { position: relative; }
.input-with-unit .field-input { padding-right: 64rpx; }
.unit { position: absolute; right: 24rpx; top: 50%; transform: translateY(-50%); font-size: 26rpx; color: #999999; }

.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 22rpx 24rpx;
  background: #f9fafb;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  box-sizing: border-box;
  line-height: 1.6;
}
.field-textarea:focus { border-color: #F97316; background: #FFFFFF; }

.field-hint { display: block; margin-top: 8rpx; font-size: 24rpx; color: #999999; }

.species-grid {
  display: flex;
  gap: 16rpx;
}
.species-card {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 12rpx;
  background: #f9fafb;
  border: 2rpx solid #E5E7EB;
  border-radius: 12rpx;
}
.species-card.active { border-color: #F97316; background: #FFF7ED; }
.species-emoji { font-size: 44rpx; }
.species-label { font-size: 26rpx; color: #666666; font-weight: 500; }
.species-card.active .species-label { color: #F97316; font-weight: 500; }
.species-check {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #F97316;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.row-fields { display: flex; gap: 20rpx; align-items: flex-start; }
.row-fields .field.half { flex: 1; min-width: 0; margin-bottom: 0; }

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FFF7ED, #FFFBF5);
  border: 2rpx solid #FED7AA;
  border-radius: 16rpx;
}
.switch-text { font-size: 28rpx; color: #9CA3AF; font-weight: 500; }
.switch-text.on { color: #16A34A; }
.switch-text.off { color: #9CA3AF; }
