/* ========== 页面容器 ========== */
.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f3f4f6;
}

/* ========== 宠物预览卡片 ========== */
.preview-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}
.preview-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  transition: background 0.3s;
}
.preview-emoji {
  font-size: 60rpx;
}
.preview-info {
  flex: 1;
  min-width: 0;
}
.preview-name {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}
.preview-meta {
  display: block;
  font-size: 26rpx;
  color: #9ca3af;
}

/* ========== 表单卡片 ========== */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

/* 字段 */
.field {
  margin-bottom: 32rpx;
}
.field:last-child {
  margin-bottom: 0;
}

.field-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 14rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}
.label-icon {
  font-size: 26rpx;
}
.required {
  color: #ef4444;
  font-weight: 400;
  margin-left: 2rpx;
}

/* 输入框 */
.field-input {
  width: 100%;
  padding: 22rpx 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #1f2937;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}
.field-input:focus {
  border-color: #3b82f6;
  background: #fff;
}
.field-input::placeholder {
  color: #cbd5e1;
}

/* 单位 */
.input-with-unit {
  position: relative;
}
.input-with-unit .field-input {
  padding-right: 64rpx;
}
.unit {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 26rpx;
  color: #9ca3af;
}

/* 文本域 */
.field-textarea {
  width: 100%;
  min-height: 140rpx;
  padding: 22rpx 24rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
  transition: border-color 0.2s, background 0.2s;
}
.field-textarea:focus {
  border-color: #3b82f6;
  background: #fff;
}
.field-textarea::placeholder {
  color: #cbd5e1;
}

.field-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #cbd5e1;
}

/* ========== 种类选择 ========== */
.species-grid {
  display: flex;
  gap: 16rpx;
}
.species-card {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 24rpx 12rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 18rpx;
  transition: all 0.2s;
}
.species-card.active {
  border-color: #3b82f6;
  background: #eff6ff;
}
.species-emoji {
  font-size: 44rpx;
}
.species-label {
  font-size: 26rpx;
  color: #6b7280;
  font-weight: 500;
}
.species-card.active .species-label {
  color: #3b82f6;
  font-weight: 600;
}
.species-check {
  position: absolute;
  top: 8rpx;
  right: 12rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #3b82f6;
  color: #fff;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 并排字段 ========== */
.row-fields {
  display: flex;
  gap: 20rpx;
}
.row-fields .field.half {
  flex: 1;
  min-width: 0;
}

/* ========== 保存按钮 ========== */
.save-bar {
  padding: 8rpx 0 40rpx;
}
.save-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(59, 130, 246, 0.35);
  transition: all 0.2s;
}
.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
