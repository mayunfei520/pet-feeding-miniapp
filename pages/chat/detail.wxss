.chat-detail-page {
  min-height: 100vh;
  background: var(--wf-cream);
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

/* ===== 骨架屏 ===== */
.skeleton-chat { padding: 24rpx 0; }
.skeleton-bubble {
  height: 80rpx;
  width: 60%;
  margin-bottom: 24rpx;
  border-radius: var(--r-md);
}
.skeleton-bubble.left { margin-right: auto; }
.skeleton-bubble.right { margin-left: auto; width: 45%; }

/* ===== 后端未接入友好态 ===== */
.chat-unready {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  text-align: center;
}
.unready-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #FFF3E8;
  color: var(--wf-orange);
  font-size: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}
.unready-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}
.unready-desc {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
  max-width: 480rpx;
}

/* ===== 演示模式横幅 ===== */
.demo-banner {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin: 16rpx 0 20rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: #FFF3E8;
  border: 1rpx solid #FED7AA;
  font-size: 22rpx;
  color: #9A3412;
  line-height: 1.5;
}
.demo-banner-icon {
  flex-shrink: 0;
  font-size: 26rpx;
}
.demo-banner-text {
  flex: 1;
}

.msg-demo-tag {
  font-size: 20rpx;
  color: #F97316;
  background: #FFF3E8;
  border: 1rpx solid #FED7AA;
  border-radius: 8rpx;
  padding: 2rpx 10rpx;
  margin: 0 12rpx;
  flex-shrink: 0;
  align-self: center;
}

/* ===== 消息列表 ===== */
.msg-list {
  padding-bottom: 150rpx;
}
.msg-row {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-end;
}
.msg-row.mine { justify-content: flex-end; }
.msg-row.peer { justify-content: flex-start; }

.msg-bubble {
  max-width: 70%;
  padding: 20rpx 24rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-break: break-word;
  box-sizing: border-box;
}
.msg-row.peer .msg-bubble {
  background: var(--wf-surface);
  color: var(--wf-ink);
  border: 1rpx solid #FFF3E8;
  border-bottom-left-radius: 8rpx;
}
.msg-row.mine .msg-bubble {
  background: var(--wf-orange);
  color: #fff;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 6rpx 16rpx rgba(249,115,22,0.18);
}
.msg-text {}
.msg-img {
  width: 280rpx;
  height: 280rpx;
  border-radius: 16rpx;
  display: block;
}

.msg-sending {
  font-size: 22rpx;
  color: var(--wf-ink-faint);
  margin: 0 12rpx;
  flex-shrink: 0;
}
.msg-retry {
  font-size: 22rpx;
  color: #DC2626;
  margin: 0 12rpx;
  flex-shrink: 0;
}

/* ===== 输入栏 ===== */
.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: var(--wf-surface);
  border-top: 1rpx solid var(--wf-border);
  box-sizing: border-box;
}
.chat-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  background: var(--wf-surface-alt);
  border: 1rpx solid var(--wf-border);
  border-radius: 9999rpx;
  font-size: 28rpx;
  color: var(--wf-ink);
  box-sizing: border-box;
}
.chat-input-ph { color: var(--wf-ink-faint); }
.chat-send-btn {
  flex-shrink: 0;
  height: 76rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 9999rpx;
  background: #FED7AA;
  color: #fff;
  font-size: 28rpx;
}
.chat-send-btn.active {
  background: var(--wf-orange);
  box-shadow: 0 6rpx 16rpx rgba(249,115,22,0.22);
}
