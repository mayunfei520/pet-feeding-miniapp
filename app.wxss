/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  color: #333;
  background: #f3f4f6;
}

.container {
  padding: 20rpx;
}

/* 卡片 */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 按钮 */
.btn {
  display: block;
  width: 100%;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}
.btn-primary {
  background: #3b82f6;
  color: #fff;
}
.btn-primary:active {
  background: #2563eb;
}
.btn-danger {
  background: #ef4444;
  color: #fff;
}
.btn-default {
  background: #fff;
  color: #333;
  border: 1px solid #d1d5db;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}
.tag-pending { background: #e0e7ff; color: #3730a3; }
.tag-accepted { background: #fef3c7; color: #92400e; }
.tag-completed { background: #d1fae5; color: #065f46; }
.tag-cancelled { background: #fee2e2; color: #991b1b; }

/* 输入框 */
.input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1px solid #d1d5db;
  border-radius: 10rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
}

/* 表单项 */
.form-item {
  margin-bottom: 24rpx;
}
.form-label {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  color: #374151;
}
.form-label .required {
  color: #ef4444;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #9ca3af;
  font-size: 28rpx;
}
