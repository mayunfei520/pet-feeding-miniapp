/* ==========================================
   宠物喂养小程序 — 全局样式（暖屋 v2.0）
   奶油底 #FFF8F1 · 暖橙 #F97316 · 暖橙 tint 柔光 · 大圆角
   设计系统见 DESIGN.md
   ========================================== */

/* ===== 设计令牌（CSS 变量） ===== */
page {
  /* 颜色 */
  --wf-cream: #FFF8F1;
  --wf-surface: #FFFFFF;
  --wf-surface-alt: #FFFBF7;
  --wf-orange: #F97316;
  --wf-orange-light: #FB923C;
  --wf-orange-deep: #EA580C;
  --wf-orange-tint: #FFF7ED;
  --wf-peach: #FFEDD5;
  --wf-green: #34D399;
  --wf-ink: #2B2420;
  --wf-ink-mid: #4A3F38;
  --wf-ink-muted: #8A7F78;
  --wf-ink-faint: #B8A99C;
  --wf-border: #F0E6DC;
  --wf-shadow: rgba(249,115,22,0.08);
  /* 圆角 */
  --r-sm: 16rpx;
  --r-md: 20rpx;
  --r-lg: 28rpx;
  --r-pill: 9999rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: var(--wf-ink);
  background: var(--wf-cream);
}

/* ===== 页面容器 ===== */
.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: var(--wf-cream);
}

/* ===== 卡片 ===== */
.card {
  background: var(--wf-surface);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.card-clickable:active { background: #FFF3E8; transform: scale(0.985); }
.card-elevated {
  background: var(--wf-surface);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 16rpx 40rpx rgba(249,115,22,0.12);
}

/* ===== 按钮（胶囊化，更软更暖） ===== */
.btn {
  display: block;
  width: 100%;
  padding: 24rpx 40rpx;
  text-align: center;
  border-radius: var(--r-pill);
  font-size: 32rpx;
  border: none;
  box-sizing: border-box;
}
.btn-primary {
  background: linear-gradient(135deg, #FB923C, #F97316);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.25);
}
.btn-primary:active { background: #EA580C; transform: scale(0.97); opacity: 0.92; }
.btn-primary[disabled] {
  background: #FED7AA;
  color: #fff;
  box-shadow: none;
}

.btn-outline, .btn-out-line {
  background: #fff;
  color: #F97316;
  border: 2rpx solid #F97316;
  border-radius: var(--r-pill);
}
.btn-outline:active, .btn-out-line:active { background: #FFF7ED; }

.btn-secondary {
  background: #fff;
  color: #8A7F78;
  font-size: 28rpx;
  border: 2rpx solid #F0E6DC;
  border-radius: var(--r-pill);
  width: auto;
  display: inline-block;
}
.btn-secondary:active { background: #FFF3E8; }

.btn-danger {
  background: #DC2626;
  color: #fff;
  border-radius: var(--r-pill);
}
.btn-danger:active { background: #B91C1C; transform: scale(0.97); }

.btn-sm {
  width: auto;
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  border-radius: var(--r-pill);
  border: 2rpx solid #F0E6DC;
  background: #fff;
  color: #8A7F78;
  line-height: 1.4;
}
.btn-sm.primary {
  color: #F97316;
  border: 2rpx solid #F97316;
  background: #fff;
}
.btn-sm.danger {
  color: #DC2626;
  border: 2rpx solid #FCA5A5;
  background: #fff;
}
.btn-sm.neutral {
  color: #8A7F78;
  border: 2rpx solid #F0E6DC;
  background: #fff;
}

.save-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #FB923C, #F97316);
  color: #fff;
  border-radius: var(--r-pill);
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.25);
}
.save-btn:active { transform: scale(0.97); opacity: 0.92; }
.save-bar {
  padding: 8rpx 0 40rpx;
}
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 输入框 & 表单 ===== */
.form-item { margin-bottom: 24rpx; }
.form-label {
  display: block;
  font-size: 28rpx;
  color: var(--wf-ink);
  margin-bottom: 8rpx;
  font-weight: 500;
}
.form-label .required { color: #DC2626; }

.input,
.form-input {
  width: 100%;
  height: 92rpx;
  padding: 0 28rpx;
  background: var(--wf-surface);
  border: 2rpx solid #F0E6DC;
  border-radius: var(--r-md);
  font-size: 28rpx;
  color: var(--wf-ink);
  box-sizing: border-box;
}
.input:focus,
.form-input:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 4rpx rgba(249,115,22,0.12);
}
.form-input.error {
  border-color: #DC2626;
  background: #FEF2F2;
}
.form-error-text {
  font-size: 24rpx;
  color: #DC2626;
  margin-top: 8rpx;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx 28rpx;
  background: var(--wf-surface);
  border: 2rpx solid #F0E6DC;
  border-radius: var(--r-md);
  font-size: 28rpx;
  color: var(--wf-ink);
  box-sizing: border-box;
  line-height: 1.6;
}
.form-textarea:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 4rpx rgba(249,115,22,0.12);
}

/* ===== 标签 — 状态（暖 tint 胶囊） ===== */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: var(--r-pill);
  font-size: 22rpx;
  font-weight: 500;
}
.tag-pending    { background: #FEF3C7; color: #B45309; }
.tag-accepted   { background: #E0F2FE; color: #0369A1; }
.tag-inprogress { background: #E0F2FE; color: #0369A1; }
.tag-completed  { background: #DCFCE7; color: #16A34A; }
.tag-cancelled  { background: #FEE2E2; color: #991B1B; }
.tag-owner      { background: #FFF7ED; color: #EA580C; }
.tag-feeder     { background: #F0F9FF; color: #0369A1; }

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
  color: #8A7F78;
  font-size: 28rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.7;
}
.empty-title {
  font-size: 30rpx;
  color: #4A3F38;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #8A7F78;
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, #F3E9DE 25%, #EAD9C8 50%, #F3E9DE 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: var(--r-md);
}
@keyframes skeleton-loading {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.skeleton-line   { height: 28rpx; margin-bottom: 16rpx; }
.skeleton-title  { height: 36rpx; width: 60%; margin-bottom: 20rpx; }
.skeleton-card   { height: 160rpx; margin-bottom: 16rpx; border-radius: var(--r-lg); }

/* ===== 通用间距 ===== */
.text-center { text-align: center; }
.mt-sm { margin-top: 12rpx; }
.mt-lg { margin-top: 24rpx; }
.mb-lg { margin-bottom: 24rpx; }

/* ===== 角色主题背景（点缀式） ===== */
.bg-owner  { background: #FFF7ED; }
.bg-feeder { background: #F0F9FF; }
.bg-admin  { background: var(--wf-cream); }

/* ===== 共享组件 ===== */
.hero-owner, .header-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.hero-feeder, .header-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}
.hero-admin, .header-admin {
  background: linear-gradient(135deg, #FFF8F1, #F0E6DC);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: var(--r-pill);
  background: rgba(255,255,255,0.7);
  color: #8A7F78;
  font-size: 22rpx;
  font-weight: 500;
}

/* ===== 暖屋新增辅助类 ===== */
.page-warm { background: var(--wf-cream); min-height: 100vh; }
.card-cozy {
  background: var(--wf-surface);
  border-radius: var(--r-lg);
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #FFF3E8;
  box-shadow: 0 8rpx 24rpx rgba(249,115,22,0.08);
}
.pill {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: var(--r-pill);
  background: var(--wf-orange-tint);
  color: var(--wf-orange-deep);
  font-size: 24rpx;
  font-weight: 500;
}
.section-title-warm {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--wf-ink);
  margin-bottom: 18rpx;
}
.divider-soft {
  height: 1rpx;
  background: #F0E6DC;
  margin: 24rpx 0;
}
