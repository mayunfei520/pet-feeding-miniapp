/* ==========================================
   宠物喂养小程序 — 全局样式
   设计规范 v1.0 | 暖橙主色 #F97316
   ========================================== */

/* ===== 页面容器 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #1A1A1A;
  background: #F5F5F5;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
  background: #F5F5F5;
}

/* ===== 卡片 ===== */
.card {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}
.card-clickable:active {
  background: #f9f9f9;
}
.card-elevated {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
}

/* ===== 按钮 ===== */
.btn {
  display: block;
  width: 100%;
  padding: 24rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
  box-sizing: border-box;
}
.btn-primary {
  background: #F97316;
  color: #fff;
  font-weight: 500;
}
.btn-primary:active { background: #EA580C; }
.btn-primary[disabled] {
  background: #FED7AA;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #F97316;
  border: 1px solid #F97316;
}
.btn-outline:active { background: #FFF7ED; }

.btn-secondary {
  background: #fff;
  color: #666666;
  font-size: 28rpx;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  width: auto;
  display: inline-block;
}
.btn-secondary:active { background: #f5f5f5; }

.btn-danger {
  background: #EF4444;
  color: #fff;
}
.btn-danger:active { background: #dc2626; }

.btn-sm {
  width: auto;
  display: inline-block;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: 1px solid #E5E7EB;
  background: #fff;
  color: #666666;
  line-height: 1.4;
}
.btn-sm.primary {
  color: #F97316;
  border: 1px solid #F97316;
  background: #fff;
}
.btn-sm.danger {
  color: #EF4444;
  border: 1px solid #fca5a5;
  background: #fff;
}
.btn-sm.neutral {
  color: #666666;
  border: 1px solid #E5E7EB;
  background: #fff;
}

.save-btn {
  width: 100%;
  padding: 28rpx;
  background: #F97316;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(249,115,22,0.25);
}
.save-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}
.save-bar {
  padding: 8rpx 0 40rpx;
}
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 输入框 & 表单 ===== */
.form-item { margin-bottom: 24rpx; }
.form-label {
  display: block;
  font-size: 28rpx;
  color: #1A1A1A;
  margin-bottom: 8rpx;
  font-weight: 500;
}
.form-label .required { color: #EF4444; }

.input,
.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}
.input:focus,
.form-input:focus {
  border-color: #F97316;
}
.form-input.error {
  border-color: #EF4444;
  background: #FEF2F2;
}
.form-error-text {
  font-size: 24rpx;
  color: #EF4444;
  margin-top: 8rpx;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx 24rpx;
  background: #FFFFFF;
  border: 1px solid #E5E7EB;
  border-radius: 8rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 1.6;
}
.form-textarea:focus {
  border-color: #F97316;
}

/* ===== 标签 — 状态 ===== */
.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}
.tag-pending    { background: #FFFBEB; color: #92400E; }
.tag-accepted   { background: #EFF6FF; color: #1E40AF; }
.tag-inprogress { background: #EFF6FF; color: #1E40AF; }
.tag-completed  { background: #F0FDF4; color: #166534; }
.tag-cancelled  { background: #FEF2F2; color: #991B1B; }
.tag-owner      { background: #FFF7ED; color: #EA580C; }
.tag-feeder     { background: #F0F9FF; color: #0369A1; }

/* ===== 空状态 ===== */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 48rpx;
  color: #999999;
  font-size: 28rpx;
  text-align: center;
}
.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}
.empty-title {
  font-size: 30rpx;
  color: #666666;
  font-weight: 500;
  margin-bottom: 8rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #999999;
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s ease-in-out infinite;
  border-radius: 8rpx;
}
@keyframes skeleton-loading {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
.skeleton-line   { height: 28rpx; margin-bottom: 16rpx; }
.skeleton-title  { height: 36rpx; width: 60%; margin-bottom: 20rpx; }
.skeleton-card   { height: 160rpx; margin-bottom: 16rpx; border-radius: 12rpx; }

/* ===== 通用 ===== */
.text-center { text-align: center; }
.mt-sm { margin-top: 12rpx; }
.mt-lg { margin-top: 24rpx; }
.mb-lg { margin-bottom: 24rpx; }

/* ===== 角色主题背景（点缀式）===== */
.bg-owner  { background: #FFF7ED; }
.bg-feeder { background: #F0F9FF; }
.bg-admin  { background: #F5F5F5; }

/* ===== 共享组件 ===== */
.hero-owner, .header-owner {
  background: linear-gradient(135deg, #FFF7ED, #FFEDD5);
}
.hero-feeder, .header-feeder {
  background: linear-gradient(135deg, #F0F9FF, #E0F2FE);
}
.hero-admin, .header-admin {
  background: linear-gradient(135deg, #F5F5F5, #E5E7EB);
}

.role-badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  border-radius: 9999rpx;
  background: rgba(255,255,255,0.7);
  color: #666666;
  font-size: 22rpx;
  font-weight: 500;
}
